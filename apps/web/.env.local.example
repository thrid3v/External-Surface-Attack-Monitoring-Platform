# ---------------------------------------------------------------------------
# EASM frontend (Next.js) config
# Copy to apps/web/.env.local  ->  cp .env.local.example .env.local  (run from apps/web)
# ---------------------------------------------------------------------------

# Server-side base URL for the FastAPI backend. The BFF proxy
# (app/api/easm/[...path]) and server components use this to reach the API.
API_URL=http://127.0.0.1:8000

# Shared secret with the backend. MUST equal INTERNAL_API_SECRET in apps/api/.env.
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# NextAuth (Google sign-in).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Reserved. The client currently calls the same-origin BFF (/api/easm), so this
# is unused at runtime. Set it only if you wire the browser to call the API
# directly in production.
# NEXT_PUBLIC_API_URL=
