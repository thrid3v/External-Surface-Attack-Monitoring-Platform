# ---------------------------------------------------------------------------
# EASM backend (FastAPI) + Celery worker/beat config
# Copy to apps/api/.env  ->  cp .env.example .env   (run from apps/api)
# ---------------------------------------------------------------------------

# PostgreSQL connection (SQLAlchemy URL). Required.
DATABASE_URL=postgresql://user:password@localhost:5432/easm

# Celery broker + result backend. Required.
REDIS_URL=redis://localhost:6379/0

# Shared secret between the Next.js BFF and this API. MUST match
# INTERNAL_API_SECRET in apps/web/.env.local. The API is fail-closed and
# refuses every request without it, so set a long random value. Required.
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# CORS: comma-separated origins allowed to call the API. Also used to build
# links in alert emails.
FRONTEND_URL=http://localhost:3000

# Optional API keys — these modules degrade gracefully if unset.
SHODAN_API_KEY=
NVD_API_KEY=

# Per-scan wall-clock budget (seconds).
SCAN_TIMEOUT=300

# SSRF protection: scans targeting private/loopback/link-local/cloud-metadata
# addresses are rejected by default. Set to true ONLY if you operate an internal
# deployment and must scan RFC-1918 ranges you own.
ALLOW_PRIVATE_TARGETS=false

# Per-user scan rate limits (abuse / cost control).
MAX_CONCURRENT_SCANS_PER_USER=3
MAX_SCANS_PER_HOUR=50

# Email alert transport (server-side; per-user routing is set in the UI under
# Settings -> Notifications). Leave SMTP_HOST blank to disable email delivery —
# webhook delivery still works without it.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=easm@localhost
SMTP_STARTTLS=true
