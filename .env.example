# ===========================================================================
# EASM — combined environment reference
# ---------------------------------------------------------------------------
# For a clean setup, copy the per-app example files instead of this one:
#   cp apps/api/.env.example        apps/api/.env
#   cp apps/web/.env.local.example  apps/web/.env.local
# This file mirrors both and exists as a single-glance reference. Never commit
# real secrets. The two INTERNAL_API_SECRET values MUST be identical.
# ===========================================================================

# ---------------------------------------------------------------------------
# Backend API + worker  ->  apps/api/.env
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/easm
REDIS_URL=redis://localhost:6379/0

# CORS origins (comma-separated); also used to build links in alert emails.
FRONTEND_URL=http://localhost:3000

# Shared secret between the Next.js BFF and the API (fail-closed without it).
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# Optional API keys — modules degrade gracefully if unset.
SHODAN_API_KEY=
NVD_API_KEY=

# Per-scan wall-clock budget (seconds).
SCAN_TIMEOUT=300

# SSRF protection: reject scans of private/internal/cloud-metadata targets.
# Set true only for internal deployments scanning RFC-1918 ranges you own.
ALLOW_PRIVATE_TARGETS=false

# Per-user scan rate limits (abuse / cost control).
MAX_CONCURRENT_SCANS_PER_USER=3
MAX_SCANS_PER_HOUR=50

# Email alert transport (per-user routing is configured in Settings -> Notifications).
# Leave SMTP_HOST blank to disable email delivery — webhook delivery still works.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=easm@localhost
SMTP_STARTTLS=true

# ---------------------------------------------------------------------------
# Frontend  ->  apps/web/.env.local
# ---------------------------------------------------------------------------
API_URL=http://127.0.0.1:8000
INTERNAL_API_SECRET=change-me-to-a-long-random-string   # must equal the API value
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# NEXT_PUBLIC_API_URL=   # reserved; unused at runtime (client uses the same-origin BFF)
